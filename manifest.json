{
  "manifest_version": 3,
  "name": "InfinityVCam",
  "version": "1.0.0",
  "description": "The professional virtual camera for Google Meet. Add logos, text, overlays, and custom branding to your video calls.",
  "permissions": [
    "storage",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "files/images/Icon.png",
    "48": "files/images/Icon.png",
    "128": "files/images/Icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "files/images/Icon.png",
      "48": "files/images/Icon.png",
      "128": "files/images/Icon.png"
    }
  },
  "background": {
    "service_worker": "files/scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["files/scripts/inject.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["files/scripts/content.js"],
      "world": "ISOLATED",
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "files/images/*.png", 
        "files/scripts/inject.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}